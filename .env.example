# Supabase — copie este arquivo para .env.local e preencha com seus valores reais.
# Obtenha em: https://supabase.com/dashboard > seu projeto > Settings > API

# URL pública do projeto Supabase (seguro expor ao browser via NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co

# Chave "publishable" (anon) do Supabase — projetada para ser pública.
# A segurança dos dados é garantida pelas políticas de RLS no banco.
# NÃO confundir com a Service Role Key, que jamais deve ir para o frontend.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------------
# ⚠️  NUNCA adicione aqui (e nem no código) variáveis como:
#     SUPABASE_SERVICE_ROLE_KEY  — acesso irrestrito ao banco
#     Qualquer outro segredo de servidor (tokens, senhas, etc.)
# Essas variáveis devem existir APENAS em ambientes server-side
# e NUNCA ter o prefixo NEXT_PUBLIC_.
# ----------------------------------------------------------------
